<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Search Results</title>
  <style>
  body {
      font-family: Arial, sans-serif;
      background: #f4f6f8;
      padding: 30px;
  }

  h1, h2 {
      color: #2c3e50;
  }

  form {
      margin-bottom: 20px;
  }

  input {
      padding: 8px;
      width: 260px;
      margin-right: 10px;
  }

  button {
      padding: 8px 16px;
      background: #3498db;
      border: none;
      color: white;
      cursor: pointer;
  }

  button:hover {
      background: #2980b9;
  }

  .stats {
      background: white;
      padding: 20px;
      border-radius: 6px;
      width: 450px;
  }

  table {
      width: 100%;
      border-collapse: collapse;
  }

  th, td {
      padding: 8px;
      border-bottom: 1px solid #ddd;
  }


  </style>
</head>
<body>

<h2>🔎 Results for "<span th:text="${keyword}"></span>"</h2>

<ul>
    <li th:each="url : ${results}" th:text="${url}"></li>
</ul>

<a href="/">⬅ Back</a>

</body>
</html>
